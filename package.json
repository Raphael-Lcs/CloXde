{
  "name": "cloxde",
  "version": "0.6.0",
  "private": true,
  "description": "Local desktop console orchestrating Claude Code CLI and Codex CLI via ACP",
  "main": "out/main/index.js",
  "author": "CloXde",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "tsx scripts/test-state-machine.ts && tsx scripts/test-transcript.ts && tsx scripts/test-update-reducer.ts && tsx scripts/test-scheduler.ts && tsx scripts/test-reflection-gate.ts && tsx scripts/test-memory-score.ts",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "icon": "node scripts/build-icon.cjs",
    "shortcut": "node scripts/build-icon.cjs && powershell -ExecutionPolicy Bypass -File scripts/install-shortcut.ps1"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.36.1",
    "@agentclientprotocol/sdk": "^0.22.1",
    "@huggingface/transformers": "^4.2.0",
    "@zed-industries/codex-acp": "^0.14.0",
    "better-sqlite3": "^11.5.0",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "sqlite-vec": "^0.1.9",
    "ws": "^8.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "onnxruntime-node",
      "sharp",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.9"
  }
}
